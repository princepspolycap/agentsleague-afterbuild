# ---------------------------------------------------------------------------
# Azure Foundry project settings (REQUIRED for live demo; not needed for sim)
# ---------------------------------------------------------------------------
# For local dev, copy values from the Poly env file kept on the maintainer's
# machine at /Users/princeps/Projects/Poly186/Poly/.env. Never commit this file.

AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT=gpt-5-4

# Alternate Foundry credential pair (Poly env naming)
# Maps to: AZURE_AI_FOUNDRY_BASE_URL / AZURE_AI_FOUNDRY_KEY in Poly env
AZURE_AI_FOUNDRY_BASE_URL=
AZURE_AI_FOUNDRY_KEY=
AZURE_OPEN_AI_VERSION=2024-12-01-preview

# Foundry IQ embedding deployment for the knowledge base
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ---------------------------------------------------------------------------
# Optional: legacy connection-string style (only if SDK requires it)
# ---------------------------------------------------------------------------
AZURE_AI_PROJECT_CONNECTION_STRING=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_AI_PROJECT_NAME=

# ---------------------------------------------------------------------------
# Demo controls
# ---------------------------------------------------------------------------
# simulation = no Azure calls, mock agent outputs (default; safe for CI)
# live       = real Foundry calls (requires keys above)
DEMO_MODE=simulation

# Poly backend is an OPTIONAL tool. Leave false unless wiring the live
# deploy_landing_page tool. Demo must work with this disabled.
ENABLE_POLY_BACKEND=false
POLY_BACKEND_URL=
